{
  "name": "xds",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/themes/*",
    "internal/*"
  ],
  "scripts": {
    "build": "yarn workspace @xds/build build && yarn workspace @xds/core build && yarn workspace @xds/vega build && yarn workspace @xds/theme-default build && yarn workspace @xds/theme-neutral build && yarn workspace @xds/theme-brutalist build && yarn workspace @xds/theme-daily build && yarn workspace @xds/theme-matcha build && yarn workspace @xds/theme-stone build && yarn workspace @xds/theme-gothic build && yarn workspace @xds/theme-chocolate build && yarn workspace @xds/theme-y2k build && yarn workspace @xds/theme-butter build",
    "dev": "yarn workspace @xds/storybook dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "check:package-boundaries": "node scripts/check-package-boundaries.js",
    "check:repo": "yarn check:sync && yarn check:package-boundaries",
    "check:sync": "node scripts/check-sync.js",
    "lint": "yarn check:repo && eslint .",
    "lint:strict": "yarn check:repo && XDS_STRICT_LINT=1 eslint .",
    "storybook": "yarn workspace @xds/storybook dev",
    "storybook:build": "yarn workspace @xds/storybook build",
    "docs": "yarn workspace @xds/docs dev",
    "sync:exports": "node scripts/sync-exports.js",
    "sync:exports:check": "node scripts/sync-exports.js --check",
    "xds": "yarn workspace @xds/cli xds",
    "package:source": "node scripts/package-source.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "verify-exports": "node scripts/verify-exports.mjs",
    "release": "yarn build && changeset publish",
    "prepare": "husky install",
    "dev:sandbox": "yarn workspace @xds/core build && yarn workspace @xds/sandbox dev",
    "dev:sandbox:source": "XDS_SOURCE=1 yarn workspace @xds/sandbox dev"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jscodeshift": "^17.3.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.1.0"
  },
  "resolutions": {
    "prettier": "^3.8.3",
    "postcss": "^8.5.10",
    "**/picomatch": "^4.0.4",
    "micromatch/**/picomatch": "^2.3.2",
    "jscodeshift/**/picomatch": "^2.3.2",
    "anymatch/**/picomatch": "^2.3.2",
    "eslint/**/minimatch": "^3.1.4",
    "test-exclude/**/minimatch": "^9.0.7",
    "**/brace-expansion": "^1.1.13",
    "dompurify": "^3.3.2",
    "vite": "^6.4.2"
  },
  "packageManager": "yarn@1.22.22",
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{ts,tsx,md}": "prettier --write"
  }
}