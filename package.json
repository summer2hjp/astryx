{
  "name": "xds",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/themes/*",
    "internal/*"
  ],
  "scripts": {
    "build": "yarn workspace @xds/core build && yarn workspace @xds/theme-default build && yarn workspace @xds/theme-neutral build",
    "dev": "yarn workspace @xds/storybook dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:strict": "XDS_STRICT_LINT=1 eslint .",
    "storybook": "yarn workspace @xds/storybook dev",
    "storybook:build": "yarn workspace @xds/storybook build",
    "docs": "yarn workspace @xds/docs dev",
    "sync:exports": "node scripts/sync-exports.js",
    "sync:exports:check": "node scripts/sync-exports.js --check",
    "xds": "yarn workspace @xds/cli xds",
    "package:source": "node scripts/package-source.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "yarn build && changeset publish",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.48.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.15.0",
    "husky": "^9.1.7",
    "jscodeshift": "^17.3.0",
    "jsdom": "^27.4.0",
    "prettier": "^3.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.53.1",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^2.1.0"
  },
  "resolutions": {
    "prettier": "^3.4.0"
  },
  "packageManager": "yarn@1.22.22",
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{ts,tsx,md}": "prettier --write"
  }
}
