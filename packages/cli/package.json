{
  "name": "@xds/cli",
  "version": "0.0.12",
  "description": "XDS design system CLI \u2014 init, swizzle, theme, templates, and agent docs",
  "type": "module",
  "bin": {
    "xds": "./bin/xds.mjs"
  },
  "exports": {
    ".": "./bin/xds.mjs",
    "./json": {
      "types": "./src/types/index.d.ts",
      "import": "./src/lib/parse.mjs"
    },
    "./api": {
      "types": "./src/types/api.d.ts",
      "import": "./src/api/index.mjs"
    }
  },
  "files": [
    "bin",
    "src",
    "templates",
    "docs"
  ],
  "scripts": {
    "xds": "node bin/xds.mjs",
    "typecheck:template-docs": "tsc --project tsconfig.template-docs.json",
    "typecheck:json-api": "tsc --project tsconfig.json-api.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^12.1.0",
    "jiti": "^2.6.1"
  },
  "keywords": [
    "xds",
    "cli",
    "design-system",
    "init",
    "swizzle"
  ],
  "license": "MIT"
}
