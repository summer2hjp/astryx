{
  "name": "@xds/theme-brutalist",
  "version": "0.0.1",
  "private": false,
  "description": "Brutalist theme for XDS — zero radius, monospace, heavy borders",
  "license": "MIT",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds build-theme src/index.ts -o dist/theme.css"
  },
  "peerDependencies": {
    "@xds/core": "*"
  },
  "devDependencies": {
    "@xds/cli": "*"
  }
}
