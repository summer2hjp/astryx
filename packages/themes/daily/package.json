{
  "name": "@xds/theme-daily",
  "version": "0.0.12",
  "private": false,
  "description": "Daily theme for XDS components \u2014 warm, productivity-focused (Lucide icons)",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/source.js",
  "types": "./dist/source.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./built": {
      "types": "./dist/daily.d.ts",
      "import": "./dist/daily.js",
      "require": "./dist/daily.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/dailyTheme.ts -o dist/theme.css && tsup"
  },
  "dependencies": {
    "lucide-react": "^0.575.0"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  },
  "module": "./dist/source.mjs"
}
