{
  "name": "@xds/theme-meta",
  "version": "0.0.12",
  "private": true,
  "description": "Meta theme for XDS components \u2014 Meta's brand identity with blue accent and clean aesthetics",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/source.js",
  "types": "./dist/source.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./built": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js",
      "require": "./dist/meta.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/metaTheme.ts -o dist/theme.css && node scripts/gen-compat-css.mjs && tsup"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  },
  "module": "./dist/source.mjs"
}
