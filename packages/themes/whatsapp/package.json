{
  "name": "@xds/theme-whatsapp",
  "version": "0.0.12",
  "private": true,
  "description": "WhatsApp theme for XDS \u2014 green accent, warm grays, Roboto, rounded surfaces",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/source.js",
  "module": "./dist/source.mjs",
  "types": "./dist/source.d.ts",
  "exports": {
    ".": {
      "types": "./dist/source.d.ts",
      "import": "./dist/source.mjs",
      "require": "./dist/source.js"
    },
    "./built": {
      "types": "./dist/whatsapp.d.ts",
      "import": "./dist/whatsapp.js",
      "require": "./dist/whatsapp.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "xds theme build src/whatsappTheme.ts -o dist/theme.css && tsup"
  },
  "peerDependencies": {
    "@xds/core": "*",
    "react": ">=19"
  },
  "devDependencies": {
    "@xds/cli": "*"
  }
}
